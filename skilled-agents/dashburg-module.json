{
  "key": "skilled-agents",
  "name": "Skilled Agents",
  "version": "0.1.0",
  "description": "Skilled agent proxy and control pages with external validation hooks.",
  "dependencies": {
    "modules": [],
    "core_capabilities": []
  },
  "backend": {
    "import": "app.modules.skilled_agents.module:skilled_agents_module"
  },
  "frontend": {
    "key": "skilledagents",
    "export": "skilledAgentsModule"
  },
  "runtime": {
    "mode": "bundled-local-service",
    "service_dir": "services/skilledagents-runtime",
    "default_port": 8787,
    "start_command": "python -m skilledagents.api",
    "env_file": ".env",
    "notes": "Bundled from local skilledagents source.",
    "health_path": "/health",
    "install_command": "pip install -r requirements.txt",
    "post_install": []
  }
}
