{
  "key": "topic-insights",
  "name": "TopicInsights",
  "version": "0.1.0",
  "description": "Research layer for pains, patterns, evidence, and topic opportunity discovery.",
  "dependencies": {
    "modules": [],
    "core_capabilities": []
  },
  "backend": {
    "import": "app.modules.topic_proxy.module:topic_proxy_module"
  },
  "frontend": {
    "key": "topicinsights",
    "export": "topicInsightsModule"
  },
  "runtime": {
    "mode": "bundled-local-service",
    "service_dir": "services/topic-insights-runtime",
    "default_port": 8080,
    "start_command": "uvicorn apps.api.main:app --host 0.0.0.0 --port 8080",
    "env_file": ".env",
    "notes": "Bundled from local newtopic/OIE source.",
    "health_path": "/api/v1/health",
    "install_command": "pip install -r requirements.txt",
    "post_install": [
      "python -m apps.cli.main db-init --reset"
    ]
  }
}
