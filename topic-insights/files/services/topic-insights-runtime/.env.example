OIE_ENV=local
DATA_DIR=./data
DATABASE_URL=sqlite:///./data/oie.db

# LLM
LLM_PROVIDER=ollama
LLM_FALLBACK_PROVIDER=openai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b
OPENAI_API_KEY=
OPENAI_MODEL_PRIMARY=gpt-4o-mini
OPENAI_MODEL_EVAL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
LLM_CACHE_TTL_SECONDS=604800
LLM_TIMEOUT_SECONDS=300
LLM_BATCH_SIZE=10
LLM_MAX_CALLS_PER_RUN=40

# Large-context LLM tuning
LLM_MAX_INPUT_CHARS=24000
LLM_MAX_EXAMPLES=40
OLLAMA_NUM_CTX=32768
OLLAMA_NUM_PREDICT=2048
OLLAMA_TEMPERATURE=0.2

# Web search providers + fallback
WEB_SEARCH_PROVIDER=auto
WEB_SEARCH_FALLBACKS=ddg,serpapi,dataforseo,none
WEB_SEARCH_ENABLED=1
WEB_SEARCH_MAX_RESULTS=30
WEB_SEARCH_CACHE_TTL_SECONDS=86400
WEB_SEARCH_RETRIES=3
WEB_SEARCH_BACKOFF_BASE=1.5
WEB_SEARCH_TIMEOUT_SECONDS=20
WEB_SEARCH_MAX_WAIT_TOTAL=45
WEB_SEARCH_COOLDOWN_SECONDS=60
SERPAPI_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Concurrency
WEB_MAX_CONCURRENCY=4
REDDIT_MAX_CONCURRENCY=4
YOUTUBE_MAX_CONCURRENCY=2
LLM_LOCAL_MAX_CONCURRENCY=2
LLM_OPENAI_MAX_CONCURRENCY=4

# Ingestion
REDDIT_USER_AGENT=OIE/1.0 (contact: you@example.com)
DEFAULT_RATE_LIMIT_SLEEP=1.0
REDDIT_MAX_POSTS=50
REDDIT_MAX_COMMENT_POSTS=10
REDDIT_MAX_COMMENTS_PER_POST=120
ENABLE_YOUTUBE=false
YOUTUBE_REGION=US
YOUTUBE_API_KEY=
YOUTUBE_MAX_VIDEOS=10
YOUTUBE_MAX_COMMENTS_PER_VIDEO=50
YOUTUBE_SEARCH_MAX_RESULTS=50
ENABLE_X_TRENDS=false
X_TRENDS_URL=https://x.com/explore/tabs/trending
X_TRENDS_FALLBACK_URL=https://x.com/explore
X_TRENDS_MAX_ITEMS=20
X_TRENDS_TIMEOUT_MS=10000
X_TRENDS_NAV_TIMEOUT_MS=15000
X_TRENDS_USE_AUTH=false
X_TRENDS_STORAGE_STATE_PATH=./secrets/x_storage_state.json
X_TRENDS_LOCALE=en-US
X_TRENDS_REGION_HINT=US
X_TRENDS_DEBUG=false

# Scoring / Discovery
COMPETITION_SCAN_ENABLED=true
COMPETITION_SCAN_RESULTS=10
AUTO_DISCOVERY_ENABLED=true
AUTO_DISCOVERY_TARGET_TOPICS=20
AUTO_DISCOVERY_IDEAS_PER_RUN=5
AUTO_DISCOVERY_LIMIT_PER_TOPIC=30
GOOGLE_TRENDS_GEO=US
GOOGLE_TRENDS_TIMEFRAME=today 12-m
APPSTORE_SCAN_ENABLED=true
APPSTORE_MAX_APPS=6
APPSTORE_MAX_REVIEWS=80

# Logging
OIE_VERBOSE=false
