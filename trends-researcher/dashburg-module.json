{
  "key": "trends-researcher",
  "name": "TrendsResearcher",
  "version": "0.1.0",
  "description": "Trend harvesting and export workflow with optional IdeaFactory handoff.",
  "dependencies": {
    "modules": [],
    "core_capabilities": []
  },
  "backend": {
    "import": "app.modules.trends_proxy.module:trends_proxy_module"
  },
  "frontend": {
    "key": "trends",
    "export": "trendsModule"
  },
  "runtime": {
    "mode": "bundled-local-service",
    "service_dir": "services/trends-runtime",
    "default_port": 8400,
    "start_command": "uvicorn trend_harvester.main:app --host 0.0.0.0 --port 8400",
    "env_file": ".env",
    "notes": "Bundled from local trend-harvester source.",
    "health_path": "/api/health",
    "install_command": "pip install -e .[dev]",
    "post_install": [
      ".venv/bin/trend-harvester migrate || trend-harvester migrate"
    ]
  }
}
