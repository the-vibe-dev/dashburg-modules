# Core app
APP_ENV=dev
DATABASE_URL=sqlite:///./trend_harvester.db

# External sources
YOUTUBE_API_KEY=
REDDIT_USER_AGENT=trend-harvester/0.1
X_TRENDS_BASE_URLS=

# Local LLM (Ollama-compatible)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_BASE_URLS=
OLLAMA_MODEL=qwen3:14b
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_LARGE_MODEL=gpt-5
OPENAI_TIMEOUT_SECONDS=90
OPENAI_STRATEGY_ENABLED=true
OPENAI_KEY_FILE=./data/openai_api_key.json
TREND_CHANNEL_PROFILES_JSON=

# Runtime tuning
REQUEST_TIMEOUT_SECONDS=20
RETRIES=5
BACKOFF_BASE_SECONDS=0.5
ENABLE_SOURCE_CACHE=false
CHANNEL_METADATA_TTL_DAYS=7
CHANNEL_RANKING_MIN_OVERLAP=1
CHANNEL_RANKING_MIN_RELEVANCE_PCT=1
CHANNEL_RANKING_DEBUG_DEFAULT=false
SIMILARITY_THRESHOLD=88
LLM_CACHE_DAYS=7
LLM_MAX_PARALLEL=3
LLM_NUM_PREDICT=180
LLM_ANALYZE_NUM_PREDICT=950
LLM_ANALYZE_NUM_CTX=4096
LLM_ANALYZE_TEMPERATURE=0.15
LLM_TIMEOUT_SECONDS=120
LLM_MAX_HTTP_ATTEMPTS_PER_RUN=600

# Preset defaults
DEFAULT_RUN_SIZE=small
SMALL_YOUTUBE_LIMIT=40
SMALL_REDDIT_LIMIT=40
SMALL_TRENDS_LIMIT=20
SMALL_X_LIMIT=20
MEDIUM_YOUTUBE_LIMIT=100
MEDIUM_REDDIT_LIMIT=100
MEDIUM_TRENDS_LIMIT=50
MEDIUM_X_LIMIT=50
LARGE_YOUTUBE_LIMIT=200
LARGE_REDDIT_LIMIT=200
LARGE_TRENDS_LIMIT=100
LARGE_X_LIMIT=100

# Hard caps
MAX_YOUTUBE_LIMIT=200
MAX_REDDIT_LIMIT=200
MAX_TRENDS_LIMIT=100
MAX_X_LIMIT=100

# Novelty reranking
NOVELTY_REPEAT_PENALTY=4
NOVELTY_SKIP_PENALTY=20
NOVELTY_USED_PENALTY=30
NOVELTY_BLACKLIST_PENALTY=100
