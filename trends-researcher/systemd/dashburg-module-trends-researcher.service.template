[Unit]
Description=Dashburg Module Runtime: trends-researcher
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=__DASHGITHUB_ROOT__/services/trends-runtime
EnvironmentFile=-__DASHGITHUB_ROOT__/.env
EnvironmentFile=-__DASHGITHUB_ROOT__/services/trends-runtime/.env
ExecStart=/bin/bash -lc 'source .venv/bin/activate && exec uvicorn trend_harvester.main:app --host 0.0.0.0 --port 8400'
Restart=always
RestartSec=3
StandardOutput=append:__DASHGITHUB_ROOT__/data/module-system/logs/trends-researcher.log
StandardError=append:__DASHGITHUB_ROOT__/data/module-system/logs/trends-researcher.log

[Install]
WantedBy=default.target
