{
  "key": "discord-control",
  "name": "Discord Control",
  "version": "0.1.0",
  "description": "Discord bridge, approval, and dispatch control plane.",
  "dependencies": {
    "modules": [],
    "core_capabilities": [
      "chat-api",
      "memory",
      "orchestration",
      "remote-ops"
    ]
  },
  "backend": {
    "import": "app.modules.discord.module:discord_module"
  },
  "frontend": {
    "key": "discord",
    "export": "discordModule"
  },
  "runtime": {
    "mode": "bundled-local-service",
    "service_dir": "services/discord-bridge-runtime",
    "default_port": 9101,
    "start_command": "python discord_bridge.py",
    "env_file": ".env",
    "notes": "Bundled local bridge/bot runtime; requires Discord bot token.",
    "health_path": "/health",
    "install_command": "pip install -r requirements.txt",
    "post_install": []
  }
}
